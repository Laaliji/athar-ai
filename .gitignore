# Athar.AI/.gitignore

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.egg

# ── Environment ───────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Data & AI artifacts ───────────────────────────────────────────
chroma_db/
data/raw/
*.pkl
*.pt
*.bin
*.safetensors

# ── Node/Frontend ─────────────────────────────────────────────────
frontend/node_modules/
frontend/build/
frontend/.env
frontend/.env.local

# ── IDE & OS ──────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
.DS_Store
Thumbs.db
*.log

# ── pytest/coverage ───────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Jupyter ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Docker ────────────────────────────────────────────────────────
.dockerignore
