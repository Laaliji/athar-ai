# ═══════════════════════════════════════════════════════
# Athar.AI — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════

# ── LLM Provider ────────────────────────────────────────
# Options: "auto" (recommended), "groq", "ollama", "huggingface"
# "auto" tries Groq → Ollama → HuggingFace in priority order
LLM_PROVIDER=auto

# Groq (Free! Sign up at https://console.groq.com)
# Gives you access to Llama 3.3 70B for free
GROQ_API_KEY=

# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local — install from https://ollama.com, then: ollama pull llama3.2)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# HuggingFace (always available fallback, no key needed)
HF_MODEL=google/flan-t5-base

# ── API Server ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated allowed CORS origins
# ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Retrieval ────────────────────────────────────────────
# Number of candidate chunks to retrieve from each retriever
RETRIEVAL_TOP_K=6

# Final number of chunks after RRF fusion
RETRIEVAL_FINAL_K=3

# Hybrid search weights (must sum to 1.0)
BM25_WEIGHT=0.4
SEMANTIC_WEIGHT=0.6

# ── Chunking ─────────────────────────────────────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# ── Embeddings ───────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu   # "cpu" or "cuda"

# ── Vector Database ──────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=islamic_heritage

# ── Data ─────────────────────────────────────────────────
DATA_DIR=./data/raw
MAX_WIKIPEDIA_ARTICLES=40

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO   # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=pretty  # "pretty" or "json"

# ── Application ──────────────────────────────────────────
ENVIRONMENT=development  # "development" or "production"
DEBUG=false
